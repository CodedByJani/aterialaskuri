# =============================================
# RUOKAILUSOVELLUS - BACKEND ENVIRONMENT
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# =============================================
# SERVER CONFIGURATION
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# DATABASE
# =============================================
# MongoDB Atlas connection string
# Get from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?appName=appname
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=ruokailijatiedot

# =============================================
# JWT AUTHENTICATION
# =============================================
# Secret key for JWT tokens (24h expiration)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use different secret in production!
JWT_SECRET=your-secret-key-here-change-in-production

# =============================================
# FRONTEND CONFIGURATION
# =============================================
# Frontend URL for CORS and magic link redirects
FRONTEND_URL=http://localhost:5173

# =============================================
# EMAIL SERVICE (Resend)
# =============================================
# Email service for sending magic links
# Get API key from: https://resend.com
RESEND_API_KEY=re_your_api_key_here